'''
BASIC 
⚫ 지난 시험의 연장선
⚫ [문제 2] 현재 디렉토리에서 두 개의 디렉토리 이름을 입력 받고, 그 두 디렉
토리에 있는 파일들의 수와 이름들이 같고, 같은 이름의 파일이라면 그 크기
도 모두 같은지를 비교하여, “같음” 또는 “다름”을 출력하는 프로그램을 작
성하라. (파일의 내용이 같은지는 상관없다.)
⚫ 에서 입력된 디렉토리에 대한 에러 처리 후 다시 디렉토리 이름을 다시 입력
▪ 에러 : 애초에 그런 이름의 뭔가가 없는 경우
▪ 에러 : 있기는 있는데 디렉토리가 아닌 경우
'''
import os

def get_dir(prompt):
    while True:
        p = input(prompt).strip()
        if os.path.isdir(p):
            return p
        if os.path.exists(p):
            print("있기는 있는데 디렉토리가 아닙니다.")
        else:
            print("애초에 그런 이름의 뭔가가 없습니다.")

def get_files(d):
    f_dict = {}
    with os.scandir(d) as it:
        for e in it:
            if e.is_file():
                f_dict[e.name] = e.stat().st_size
    return f_dict

def compare():
    d1 = get_dir("첫 번째 디렉토리: ")
    d2 = get_dir("두 번째 디렉토리: ")

    if get_files(d1) == get_files(d2):
        print("같음")
    else:
        print("다름")

compare()


