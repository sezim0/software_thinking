import os


def input_directory(prompt):
    while True:
        name = input(prompt).strip()

        if not os.path.exists(name):
            print("Error: no such file or directory. Try again.")
            continue

        if not os.path.isdir(name):
            print("Error: that name exists, but it is not a directory. Try again.")
            continue

        try:
            os.listdir(name)
        except PermissionError:
            print("Error: no permission to read that directory. Try again.")
            continue

        return name


def collect_tree(directory, relative_path=""):
    result = {}

    try:
        names = os.listdir(directory)
    except PermissionError:
        result[relative_path] = ("NO_PERMISSION", None)
        return result

    for name in names:
        full_path = os.path.join(directory, name)
        child_relative = os.path.join(relative_path, name)

        if os.path.isdir(full_path):
            result[child_relative] = ("DIR", None)
            result.update(collect_tree(full_path, child_relative))
        elif os.path.isfile(full_path):
            result[child_relative] = ("FILE", os.path.getsize(full_path))
        else:
            pass

    return result


dir1 = input_directory("First directory name: ")
dir2 = input_directory("Second directory name: ")

tree1 = collect_tree(dir1)
tree2 = collect_tree(dir2)

if tree1 == tree2:
    print("같음")
else:
    print("다름")






  




 

