import os

# --- 1. The Short Helper Function ---
def get_files(path, base=""):
    result = {}
    
    # os.scandir() is required by the professor
    with os.scandir(path) as entries:
        for entry in entries:
            # Create relative name (e.g., "subfolder/a.txt")
            rel_name = os.path.join(base, entry.name)
            
            if entry.is_file():
                # Just save the path! Nothing else.
                result[rel_name] = entry.path         
            elif entry.is_dir():
                # Recursion: Required by the professor to check sub-directories
                result.update(get_files(entry.path, rel_name))
                
    return result

# --- 2. The Simple Comparison ---
def compare_folders():
    dir1 = input("Enter Folder 1: ")
    dir2 = input("Enter Folder 2: ")
    
    files1 = get_files(dir1)
    files2 = get_files(dir2)
    
    # Check 1: File Count
    if len(files1) != len(files2):
        print("❌ Different number of files.")
        return
        
    # Check 2: Names, Sizes, and Content
    for name in files1:
        # Check if the name exists in Folder 2
        if name not in files2:
            print(f"❌ '{name}' is missing in Folder 2.")
            return
            
        # Get the full computer paths for both files
        p1 = files1[name]
        p2 = files2[name]
        
        # Compare Size using os.stat() as required by the professor
        if os.stat(p1).st_size != os.stat(p2).st_size:
            print(f"❌ Size mismatch for '{name}'.")
            return
            
        # Compare Content (Using 'rb' to safely read ANY file type)
        with open(p1, 'rb') as f1, open(p2, 'rb') as f2:
            if f1.read() != f2.read():
                print(f"❌ Content mismatch for '{name}'.")
                return

    print("✅ Success! Both folders are perfectly identical.")

# --- 3. Run it ---
compare_folders()
