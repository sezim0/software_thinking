import os

def get_all_files(folder_path, base_path=""):
    """
    Digs through a folder and returns a dictionary of all files.
    The dictionary uses the 'relative path' (name) as the key, 
    and a tuple of (size, full_path) as the value.
    """
    files_dict = {}
    
    try:
        with os.scandir(folder_path) as entries:
            for entry in entries:
                # Calculate the path relative to the top folder so we can compare Dir A and Dir B accurately
                relative_path = os.path.join(base_path, entry.name)
                
                if entry.is_file():
                    # os.stat().st_size gets the exact file size in bytes as requested by the prof
                    file_size = os.stat(entry.path).st_size 
                    files_dict[relative_path] = (file_size, entry.path)
                
                elif entry.is_dir():
                    # Recursion: Dig into sub-folders and combine the results
                    sub_files = get_all_files(entry.path, relative_path)
                    files_dict.update(sub_files)
    except (FileNotFoundError, PermissionError):
        pass
        
    return files_dict

def compare_directories(dir1, dir2):
    print(f"\nScanning: {dir1} and {dir2}...\n")
    
    # 1. Get all files from both directories
    files1 = get_all_files(dir1)
    files2 = get_all_files(dir2)
    
    # 2. Check if they have the SAME NUMBER of files
    if len(files1) != len(files2):
        print(f"❌ FAIL: Different number of files. ({dir1} has {len(files1)}, {dir2} has {len(files2)})")
        return
    else:
        print(f"✅ PASS: Both directories have {len(files1)} files.")

    # 3. Check File Names, Sizes, and Contents
    for rel_path in files1:
        # Check if the exact filename exists in Directory 2
        if rel_path not in files2:
            print(f"❌ FAIL: File '{rel_path}' is missing in {dir2}.")
            return
            
        size1, full_path1 = files1[rel_path]
        size2, full_path2 = files2[rel_path]
        
        # Check if sizes match using os.stat() data
        if size1 != size2:
            print(f"❌ FAIL: Size mismatch for '{rel_path}'. ({size1} bytes vs {size2} bytes)")
            return
            
        # Check if contents match by reading the files
        with open(full_path1, 'rb') as f1, open(full_path2, 'rb') as f2:
            if f1.read() != f2.read():
                print(f"❌ FAIL: Content mismatch inside '{rel_path}'. The text/data is different.")
                return

    print("✅ SUCCESS: Both directories are perfectly identical in names, sizes, and contents!")

# Get input from the user
folder1 = input("Enter the FIRST directory path: ")
folder2 = input("Enter the SECOND directory path: ")

compare_directories(folder1, folder2)
