import calendar

class CalendarBot:
    def __init__(self):
        # This part sets up the "machine"
        self.year = 2015
        self.output_style = calendar.TextCalendar(calendar.SUNDAY)

    def print_month(self, month_number):
        # This part is the "action" the machine performs
        grid = self.output_style.formatmonth(self.year, month_number)
        print(grid)

# --- HOW TO USE IT ---
bot = CalendarBot() # Create one instance of the machine
bot.print_month(10) # Tell the machine to do its job for month 10




