import calendar

# 1. Setup: Use 2015 and start weeks on Sunday
cal = calendar.TextCalendar(calendar.SUNDAY)

while True:
    val = input("Enter month (1-12) or 'q' to quit: ")

    if val.lower() == 'q':
        break  # Stop the program
    
    # 2. Check if the input is a number
    if val.isdigit():
        month_num = int(val)
        # 3. Print the calendar for the year 2015 and the month chosen
        print(cal.formatmonth(2015, month_num))
    else:
        print("Invalid input.")
